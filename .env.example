# DeshGPT ULTIMATE - Environment Variables Template
# Copy this to .env and fill in your actual API keys

# ============================================================================
# REQUIRED APIs - MUST SET THESE
# ============================================================================

# Groq API Key (REQUIRED for chat)
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXX

# Google Gemini API Key (REQUIRED for image analysis)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# OPTIONAL APIs - For Extra Features
# ============================================================================

# OpenWeatherMap API Key (OPTIONAL - for weather feature)
# Get from: https://openweathermap.org/api
# Free tier: 1,000 calls/day
OPENWEATHER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXX

# Alpha Vantage API Key (OPTIONAL - for stock prices)
# Get from: https://www.alphavantage.co/
# Free tier: 5 requests/minute
ALPHA_VANTAGE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# Flask Configuration
# ============================================================================

FLASK_ENV=production
FLASK_DEBUG=False

# Server Port
PORT=5000
