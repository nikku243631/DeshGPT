# ─────────────────────────────────────────────────────────────
# DeshGPT — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Is file ko copy karke ".env" naam do aur apni keys bharo.
# Render pe: Settings > Environment Variables mein add karo.
# ─────────────────────────────────────────────────────────────

# ✅ REQUIRED — Chat kaam nahi karega bina iske
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ✅ REQUIRED — Image analysis ke liye (Photo feature)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ⚡ OPTIONAL — Weather API (bina iske wttr.in fallback use hoga)
# Free tier: https://openweathermap.org/api
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ⚡ OPTIONAL — Stock prices (bina iske Yahoo Finance scraping hoga)
# Free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=XXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────────────────────
FLASK_ENV=production
PORT=5000